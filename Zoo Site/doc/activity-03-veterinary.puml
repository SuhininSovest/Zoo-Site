@startuml activity-03-veterinary
title Деятельность: медосмотр, прививки, лечение и стационар

|Ветеринар|
start
:Открыть карточку особи;

partition "Медосмотр" {
  :Внести дату осмотра,\nвес, рост, оценку развития,\nтекстовые наблюдения;
  |Система|
  :Сохранить запись медосмотра\nв истории особи;
}

partition "Прививки" {
  |Ветеринар|
  :Запланировать прививку\n(тип, плановая дата);
  |Система|
  :Добавить в график;
  |Ветеринар|
  :Отметить факт вакцинации\n(дата, препарат, доза);
  |Система|
  :Закрыть пункт графика\nили перенести при необходимости;
}

partition "Лечение и изоляция" {
  |Ветеринар|
  if (Требуется лечение?) then (да)
    :Создать назначение лечения\n(начало, описание процедур);
    if (Нужна изоляция\nв стационаре?) then (да)
      :Оформить изоляцию\n(клетка/бокс стационара, срок);
      |Система|
      :Изменить статус особи\n«на лечении / изоляция»;
      |Сотрудник стационара|
      :Вести статус ухода\n(на лечении / готов к выписке);
      |Ветеринар|
      :Оценить исход лечения;
      |Система|
      :Зафиксировать результат лечения;
      |Ветеринар|
      :Снять изоляцию / выписка\nпри выполнении условий;
      |Система|
      :Вернуть особь\nв обычный режим учёта;
    else (нет)
      :Вести амбулаторное лечение\nбез изоляции;
    endif
  else (нет)
  endif
}

stop
@enduml
