@startuml activity-06-feeding-supply
title Деятельность: рационы, меню на день, корма, поставщики и заказы

|Администрация|
start

partition "Справочники и правила" {
  :Вести типы кормов\n(растительный, живой, мясо,\nкомбикорм и подтипы);
  :Указать поставщиков\nи их специализацию по кормам;
  :Отметить корма\nсобственного производства\n(сено, мыши и т.п.);
  :Задать правила рациона\nпо виду, возрасту, состоянию,\nсезону;
}

partition "Меню на день" {
  |Система|
  :Для каждой особи определить\nактуальный сезон и состояние;
  :Подобрать правило рациона;
  :Сформировать позиции меню:\nвремя, количество, вид корма;
  |Администрация|
  :Просмотреть и при необходимости\nскорректировать вручную;
  |Система|
  :Сохранить меню на дату;
}

partition "Потребность и закупки" {
  |Система|
  :Агрегировать потребность\nпо меню и запасам;
  :Запросить остатки\nу ИС складского учёта;
  if (Выявлен дефицит?) then (да)
    |Администрация|
    :Сформировать заказ\nна корма у поставщиков;
    |Система|
    :Отправить заказ\nв ИС поставщика;
    :Получить статусы\nисполнения поставки;
    :Обновить ожидаемые поступления;
  else (нет)
  endif
}

|Дрессировщик|
:Просмотреть меню кормления\nна день для закреплённых особей;

stop
@enduml
